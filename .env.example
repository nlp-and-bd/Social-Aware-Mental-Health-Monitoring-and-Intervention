# --- Reddit (app-only OAuth: read-only public data, no login required) ---
# Create app at https://www.reddit.com/prefs/apps  (type: script)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=python:mlops-social-trends:1.0.0 (by /u/<your_reddit_username>)
REDDIT_REDIRECT_URI=http://localhost:8000/api/auth/callback


# --- MongoDB Atlas ---
# Format: mongodb+srv://<user>:<pwd>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=<app>
MONGODB_URI=
MONGODB_DB=mental_health_db

MONGO_DB_RAW=mh_raw
MONGO_DB_PII=mh_pii
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Encryption key for usernames in mh_pii ---
# Generate once with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
MENTALBERT_MODEL_PATH=./models/v2
EMBEDDING_MODEL=all-MiniLM-L6-v2

